DATABASE_URL=sqlite+aiosqlite:///./opa.db
ANTHROPIC_API_KEY=your_key_here
AWS_PROFILE=default
AWS_REGION=us-east-1
LANGFUSE_PUBLIC_KEY=your_key_here
LANGFUSE_SECRET_KEY=your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
SECRET_KEY=dev-secret-key-change-in-production
ENVIRONMENT=development
# Extra CORS origins (comma-separated) ADDED on top of the baked-in dev+prod
# hosts. Use this for a remote dev box (e.g. an EC2 public hostname) instead of
# hardcoding it in config.py — dev normally talks same-origin via the Vite /api
# proxy, so this is only needed if a browser hits the backend :8001 directly.
# CORS_ALLOW_ORIGINS=http://ec2-xx-xx.compute.amazonaws.com:5174
CORS_ALLOW_ORIGINS=
ML_MODELS_DIR=./ml_models
# Dollar gate above which a terminal case decision is held for supervisor approval.
HIGH_DOLLAR_THRESHOLD=2000
# EmailJS configuration for provider delivery notifications (optional)
EMAILJS_SERVICE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_TEMPLATE_ID_SECURE_LINK=
EMAILJS_TEMPLATE_ID_OTP=
EMAILJS_TEMPLATE_ID_NOTIFY_PAYER=
