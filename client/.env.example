# Cross-app URLs for the platform suite (PayGuard + sibling apps).
#
# Each app deploys separately, so these links differ per environment. Copy this
# file to `.env` (or `.env.production`) and set real hosts for production.
#
# IMPORTANT: Vite inlines VITE_* vars at BUILD time, not runtime. On Railway they
# must be set as build-time environment variables so `npm run build` picks them up.
#
# Defaults (when unset) are the pinned local dev ports — see src/config/appUrls.ts.

# Backend API base URL. Leave unset for dev (Vite proxies /api to :8001) or for
# same-origin deploys where the backend serves the built frontend. Set it when the
# frontend is deployed as a separate service from the API.
#   VITE_API_URL=https://api.example.com
VITE_API_URL=

# IAM Admin app
VITE_IAM_URL=http://localhost:5177

# PayGuard (this app — post-pay overpayment recovery)
VITE_PAYGUARD_URL=http://localhost:5174

# ClaimGuard (pre-pay claim review)
VITE_CLAIMGUARD_URL=http://localhost:5175

# SIU (special investigations workspace)
VITE_SIU_URL=http://localhost:5178
