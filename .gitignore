node_modules/
client/dist/
client/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Local DBs (regenerate via `make seed`) ───────────────────────────────
*.db
*.db.bak
*.db-journal
*.db-shm
*.db-wal

# ── ML artifacts (regenerate via training) ──────────────────────────────
server/ml_models/*.pkl

# ── Uploaded documents (PDF intake; user-supplied artifacts) ─────────────
server/uploads/

# ── Environment / secrets ────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── OS / editor ──────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# ── Build / packaging ────────────────────────────────────────────────────
build/
dist/
*.egg
# tsc outputs of vite.config.ts (generated; not source)
client/vite.config.js
client/vite.config.d.ts
# stale build snapshot parked aside during local/remote dev
client/dist.stale/

# ── Local scratch / throwaway harnesses ──────────────────────────────────
# Underscore-prefixed one-off scripts at the server root (e.g. _verify_split.py)
server/_*.py
# Ad-hoc contract/document inputs dropped in while iterating on the demo
server/contracts/

# Raw OIG LEIE download — trimmed/committed copy lives at server/seed/data/leie_npi.csv
UPDATED.csv
